#!/usr/bin/env python3
"""Smoke check for the {{skill_name}} skill."""

from __future__ import annotations

import sys
from pathlib import Path


SKILL_ROOT = Path(__file__).resolve().parents[1]


def find_repo_root(start: Path) -> Path:
    for candidate in (start, *start.parents):
        if (candidate / "scripts" / "market_utils.py").is_file():
            return candidate
    raise RuntimeError("could not locate repository root containing scripts/market_utils.py")


REPO_ROOT = find_repo_root(SKILL_ROOT)
if str(REPO_ROOT / "scripts") not in sys.path:
    sys.path.insert(0, str(REPO_ROOT / "scripts"))

from market_utils import validate_market_manifest  # noqa: E402


REQUIRED_FILES = (
    SKILL_ROOT / "SKILL.md",
    SKILL_ROOT / "agents" / "openai.yaml",
    SKILL_ROOT / "references" / "topic-guide.md",
    SKILL_ROOT / "assets" / "output-template.md",
    SKILL_ROOT / "market" / "skill.json",
)


def main() -> int:
    errors: list[str] = []
    for path in REQUIRED_FILES:
        if not path.is_file():
            errors.append(f"missing required file: {path.relative_to(SKILL_ROOT).as_posix()}")

    manifest_path = SKILL_ROOT / "market" / "skill.json"
    if manifest_path.is_file():
        _, manifest_errors = validate_market_manifest(manifest_path)
        errors.extend(manifest_errors)

    if errors:
        for error in errors:
            print(f"ERROR: {error}")
        return 1

    print("{{skill_name}} skill check passed.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
