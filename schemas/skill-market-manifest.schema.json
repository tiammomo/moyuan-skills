{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.dev/schemas/skill-market-manifest.schema.json",
  "title": "Skill Market Manifest",
  "type": "object",
  "required": [
    "id",
    "publisher",
    "name",
    "title",
    "version",
    "channel",
    "summary",
    "description",
    "categories",
    "tags",
    "compatibility",
    "permissions",
    "quality",
    "lifecycle",
    "artifacts",
    "search",
    "distribution"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "publisher": { "type": "string", "minLength": 2 },
    "name": { "type": "string", "minLength": 2 },
    "title": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "minLength": 3 },
    "channel": { "type": "string", "enum": ["stable", "beta", "internal"] },
    "summary": { "type": "string", "minLength": 20 },
    "description": { "type": "string", "minLength": 40 },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "compatibility": {
      "type": "object",
      "required": ["codex_min_version", "python", "platforms"],
      "properties": {
        "codex_min_version": { "type": "string", "minLength": 3 },
        "python": { "type": "string", "minLength": 3 },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["windows", "macos", "linux"] }
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["workspace", "network", "shell", "secrets", "human_review_required"],
      "properties": {
        "workspace": { "type": "string", "enum": ["none", "read", "write"] },
        "network": { "type": "string", "enum": ["none", "limited", "full"] },
        "shell": { "type": "string", "enum": ["none", "limited", "full"] },
        "secrets": { "type": "string", "enum": ["none", "read", "write"] },
        "human_review_required": { "type": "boolean" }
      }
    },
    "quality": {
      "type": "object",
      "required": ["checker", "eval", "review_status"],
      "properties": {
        "checker": { "type": "string", "minLength": 5 },
        "eval": { "type": "string", "minLength": 5 },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "deprecated"] }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["active", "deprecated", "blocked", "archived"] },
        "replacement_skill_id": { "type": "string" },
        "sunset_at": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["source_dir", "entrypoint", "docs"],
      "properties": {
        "source_dir": { "type": "string", "minLength": 5 },
        "entrypoint": { "type": "string", "minLength": 5 },
        "docs": { "type": "string", "minLength": 5 }
      }
    },
    "search": {
      "type": "object",
      "required": ["keywords", "related_skills"],
      "properties": {
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 2 }
        },
        "related_skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        }
      }
    },
    "distribution": {
      "type": "object",
      "required": ["capabilities", "starter_bundle_ids"],
      "properties": {
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "starter_bundle_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        }
      }
    }
  }
}
