{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.dev/schemas/installed-history-waiver-source-reconcile-waiver-apply-policy.schema.json",
  "title": "Installed History Waiver Source Reconcile Waiver Apply Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_version",
    "id",
    "title",
    "description",
    "defaults"
  ],
  "properties": {
    "policy_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_states",
        "require_report_complete",
        "fail_on_blocked_execution",
        "fail_on_pending_verification",
        "fail_on_blocked_verification",
        "fail_on_verification_drift"
      ],
      "properties": {
        "allowed_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "require_report_complete": {
          "type": "boolean"
        },
        "fail_on_blocked_execution": {
          "type": "boolean"
        },
        "fail_on_pending_verification": {
          "type": "boolean"
        },
        "fail_on_blocked_verification": {
          "type": "boolean"
        },
        "fail_on_verification_drift": {
          "type": "boolean"
        }
      }
    }
  }
}
