{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.example/schemas/installed-history-waiver-source-reconcile-waiver.schema.json",
  "title": "Installed History Waiver Source Reconcile Gate Waiver",
  "type": "object",
  "required": [
    "waiver_version",
    "id",
    "title",
    "description",
    "policy_id",
    "match",
    "approval"
  ],
  "properties": {
    "waiver_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "policy_id": {
      "type": "string",
      "minLength": 3
    },
    "match": {
      "type": "object",
      "required": [
        "finding_codes"
      ],
      "properties": {
        "finding_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "incomplete_report",
              "disallowed_report_state",
              "blocked_execution",
              "pending_verification",
              "blocked_verification",
              "verification_drift"
            ]
          }
        },
        "report_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "needs_execution",
              "drifted",
              "needs_verification_followup",
              "verified",
              "no_reconcile_actions",
              "review_required"
            ]
          }
        },
        "target_root_suffix": {
          "type": "string",
          "minLength": 1
        },
        "stage_dir_suffix": {
          "type": "string",
          "minLength": 1
        },
        "action_waiver_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "action_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": [
        "approved_by",
        "approved_at",
        "reason"
      ],
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 3
        },
        "approved_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reason": {
          "type": "string",
          "minLength": 20
        }
      },
      "additionalProperties": false
    },
    "expires_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
