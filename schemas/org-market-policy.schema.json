{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.dev/schemas/org-market-policy.schema.json",
  "title": "Org Market Policy",
  "type": "object",
  "required": [
    "org_id",
    "display_name",
    "include_channels",
    "allowed_publishers",
    "allowed_review_statuses",
    "allowed_lifecycle_statuses",
    "allowed_skills",
    "blocked_skills",
    "preferred_skills",
    "featured_bundles",
    "require_verified_publishers"
  ],
  "properties": {
    "org_id": { "type": "string", "minLength": 3 },
    "display_name": { "type": "string", "minLength": 3 },
    "include_channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["stable", "beta", "internal"] }
    },
    "allowed_publishers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "allowed_review_statuses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["draft", "reviewed", "deprecated"] }
    },
    "allowed_lifecycle_statuses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["active", "deprecated", "blocked", "archived"] }
    },
    "allowed_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "blocked_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "preferred_skills": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "featured_bundles": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "require_verified_publishers": { "type": "boolean" }
  }
}
