{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.example/schemas/installed-history-alert-waiver.schema.json",
  "title": "Installed History Alert Waiver",
  "type": "object",
  "required": [
    "waiver_version",
    "id",
    "title",
    "description",
    "policy_id",
    "match",
    "approval"
  ],
  "properties": {
    "waiver_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "policy_id": {
      "type": "string",
      "minLength": 3
    },
    "match": {
      "type": "object",
      "required": [
        "metrics"
      ],
      "properties": {
        "before_entry": {
          "type": "integer",
          "minimum": 1
        },
        "after_entry": {
          "type": "integer",
          "minimum": 1
        },
        "before_target_root_suffix": {
          "type": "string",
          "minLength": 1
        },
        "after_target_root_suffix": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "added_skills",
              "removed_skills",
              "changed_skills",
              "added_bundles",
              "removed_bundles",
              "changed_bundles",
              "installed_delta",
              "bundle_delta"
            ]
          }
        },
        "removed_skill_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "removed_bundle_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": [
        "approved_by",
        "approved_at",
        "reason"
      ],
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 3
        },
        "approved_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reason": {
          "type": "string",
          "minLength": 20
        }
      },
      "additionalProperties": false
    },
    "expires_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
