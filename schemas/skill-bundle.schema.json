{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.dev/schemas/skill-bundle.schema.json",
  "title": "Skill Starter Bundle",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "description",
    "status",
    "channels",
    "skills",
    "use_cases",
    "keywords"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 20 },
    "description": { "type": "string", "minLength": 40 },
    "status": { "type": "string", "enum": ["draft", "published"] },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["stable", "beta", "internal"] }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    }
  }
}
