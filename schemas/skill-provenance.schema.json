{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moyuan.dev/schemas/skill-provenance.schema.json",
  "title": "Skill Provenance Attestation",
  "type": "object",
  "required": [
    "attestation_format",
    "skill_id",
    "skill_name",
    "publisher",
    "version",
    "channel",
    "generated_at",
    "builder",
    "manifest_path",
    "source_dir",
    "manifest_checksum_sha256",
    "source_tree_checksum_sha256",
    "package",
    "quality",
    "lifecycle",
    "files"
  ],
  "properties": {
    "attestation_format": { "type": "string", "minLength": 5 },
    "skill_id": { "type": "string", "minLength": 3 },
    "skill_name": { "type": "string", "minLength": 2 },
    "publisher": { "type": "string", "minLength": 2 },
    "version": { "type": "string", "minLength": 3 },
    "channel": { "type": "string", "enum": ["stable", "beta", "internal"] },
    "generated_at": { "type": "string", "minLength": 10 },
    "builder": { "type": "string", "minLength": 5 },
    "manifest_path": { "type": "string", "minLength": 5 },
    "source_dir": { "type": "string", "minLength": 5 },
    "manifest_checksum_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_tree_checksum_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "package": {
      "type": "object",
      "required": ["path", "checksum_sha256", "size_bytes"],
      "properties": {
        "path": { "type": "string", "minLength": 5 },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "quality": {
      "type": "object",
      "required": ["checker", "eval", "review_status"],
      "properties": {
        "checker": { "type": "string", "minLength": 5 },
        "eval": { "type": "string", "minLength": 5 },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "deprecated"] }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["active", "deprecated", "blocked", "archived"] },
        "replacement_skill_id": { "type": "string" },
        "sunset_at": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 5 },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
